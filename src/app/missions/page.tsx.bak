// src/app/missions/page.tsx
import type { Metadata } from "next";
import { fetchMissions } from "@/services/wf-api.service";
import { Zap, Shield, Star, BookOpen } from "lucide-react";
import MissionCard from "@/components/missions/MissionCard";

export const metadata: Metadata = { title: "Миссии PvE" };
export const revalidate = 600; // 10 min

type Mission = Awaited<ReturnType<typeof fetchMissions>>[0];

function Section({ title, icon, items, accent }: {
  title: string; icon: React.ReactNode; items: Mission[]; accent?: string;
}) {
  if (items.length === 0) return null;
  return (
    <section>
      <h2 className={`text-sm font-semibold uppercase tracking-widest mb-4 flex items-center gap-2 ${accent ?? "text-wf-muted_text"}`}>
        {icon}{title}
        <span className="ml-1 text-xs font-normal text-wf-muted_text">({items.length})</span>
      </h2>
      <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {items.map((m, i) => <MissionCard key={i} m={m} />)}
      </div>
    </section>
  );
}

export default async function MissionsPage() {
  const missions = await fetchMissions();
  const specOps  = missions.filter((m) => m.is_special_operation === "1");
  const survival = missions.filter((m) => m.is_infinity_survival === "1");
  const tutorial = missions.filter((m) => m.tutorial_mission === "1");
  const regular  = missions.filter((m) => m.is_special_operation === "0" && m.is_infinity_survival === "0" && m.tutorial_mission === "0");

  return (
    <main className="min-h-screen bg-wf-bg text-wf-text">
      <div className="border-b border-wf-border bg-wf-surface">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
          <h1 className="text-2xl font-bold flex items-center gap-2">
            <Zap className="w-6 h-6 text-wf-accent" /> Миссии PvE
          </h1>
          <p className="text-sm text-wf-muted_text mt-1">
            {missions.length} активных · обновляется каждые 10 минут
          </p>
        </div>
      </div>
      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-10">
        <Section title="Спецоперации" icon={<Star  className="w-3.5 h-3.5" />} items={specOps}  accent="text-wf-accent" />
        <Section title="Выживание"    icon={<Shield className="w-3.5 h-3.5" />} items={survival} accent="text-blue-400" />
        <Section title="Обучение" icon={<BookOpen className="w-3.5 h-3.5" />} items={tutorial} accent="text-green-400" />
        <Section title="Обычные миссии" icon={<Zap className="w-3.5 h-3.5" />} items={regular} />
        {missions.length === 0 && (
          <div className="text-center py-20 text-wf-muted_text">
            <Zap className="w-12 h-12 opacity-20 mx-auto mb-3" />
            <p>Нет активных миссий</p>
          </div>
        )}
      </div>
    </main>
  );
}
