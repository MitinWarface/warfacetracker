# ===========================================
# WARFACE TRACKER - VERCEL ENVIRONMENT
# ===========================================
# Добавьте эти переменные в Vercel Project Settings > Environment Variables

# ===========================================
# DATABASE (Vercel Postgres / Neon)
# ===========================================
# Основной URL (через пул коннекций Vercel)
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# Прямой URL для миграций Prisma (без пулинга)
DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# ===========================================
# REDIS (Vercel KV / Upstash)
# ===========================================
REDIS_URL="redis://default:password@xxx.upstash.io:6379"

# ===========================================
# APP SETTINGS
# ===========================================
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
APP_SECRET="your-super-secret-key-min-32-chars"

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60

# ===========================================
# CACHE TTL (в секундах)
# ===========================================
CACHE_TTL_PLAYER=900
CACHE_TTL_CLAN=1800
CACHE_TTL_MISSIONS=600
CACHE_TTL_RATINGS=300
