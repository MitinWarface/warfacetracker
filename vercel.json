{
  "buildCommand": "npm run vercel:build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "regions": ["fra1"],
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://your-app.vercel.app"
  },
  "build": {
    "env": {
      "NODE_ENV": "production"
    }
  }
}
