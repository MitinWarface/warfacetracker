# Direct connection (для миграций Prisma) - порт 5432
DIRECT_URL="postgresql://postgres.rrhkcxauserjtioyarui:IqLIJ6bdzDQsYIVh@aws-1-eu-west-1.pooler.supabase.com:5432/postgres"

# ===========================================
# REDIS (Upstash recommended for Vercel)
# ===========================================
# Получить: https://upstash.com → Create Database → Copy REST URL
REDIS_URL="redis://default:password@host:port"

# Пример для Upstash:
# REDIS_URL="redis://defaultABCDEFGHIJKLMNOPQRSTUV==@us-east-1.upstash.io:6379"

# ===========================================
# APP SETTINGS
# ===========================================
# URL вашего приложения (для продакшена укажите ваш домен)
NEXT_PUBLIC_APP_URL="https://warfacetracker.vercel.app"

# СЕКРЕТЫ УЖЕ СГЕНЕРИРОВАНЫ ✅
# Для Vercel используйте эти или сгенерируйте новые:
APP_SECRET="xK9#mP2$vL5@nQ8&wR3^tY6*uI1!oA4%sD7"
JWT_SECRET="jH8#kL3$mN6@pQ1&rS9^tV2*wX5!yB0%cE4"

# ===========================================
# RATE LIMITING
# ===========================================
# Максимальное количество запросов
RATE_LIMIT_MAX=10

# Окно времени в секундах
RATE_LIMIT_WINDOW=60

# ===========================================
# CACHE TTL (в секундах)
# ===========================================
# Кэш статистики игрока (15 минут)
CACHE_TTL_PLAYER=900

# Кэш кланов (30 минут)
CACHE_TTL_CLAN=1800

# Кэш миссий (10 минут)
CACHE_TTL_MISSIONS=600

# Кэш рейтингов (5 минут)
CACHE_TTL_RATINGS=300

# ===========================================
# CDN & API ENDPOINTS
# ===========================================
# Основной CDN для изображений
NEXT_PUBLIC_CDN_URL="https://cdn.wfts.su"

# Warface API (используется на сервере)
WARFACE_API_URL="http://api.warface.ru"

# Warface Wiki для парсинга
WARFACE_WIKI_URL="https://ru.warface.com/wiki"

# ===========================================
# ОПЦИОНАЛЬНО
# ===========================================
# Для отладки
# NODE_ENV="production"
# DEBUG="true"
