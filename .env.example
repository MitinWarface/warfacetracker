# ===========================================
# WARFACE TRACKER - ENVIRONMENT VARIABLES
# ===========================================
# Скопируйте этот файл в .env и заполните значениями

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
# Для локальной разработки
DATABASE_URL="postgresql://postgres:password@localhost:5432/warface_tracker"

# Для продакшена (примеры):
# Railway: DATABASE_URL="postgresql://user:pass@railway-database-url:5432/dbname"
# Neon: DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require"
# Supabase: DATABASE_URL="postgresql://postgres:pass@db.supabase.co:5432/postgres"

# ===========================================
# REDIS
# ===========================================
# Для локальной разработки
REDIS_URL="redis://localhost:6379"

# Для продакшена (примеры):
# Upstash: REDIS_URL="redis://default:password@host:port"
# Redis Cloud: REDIS_URL="redis://user:pass@redis-host:6379"

# ===========================================
# APP SETTINGS
# ===========================================
# URL вашего приложения (для продакшена укажите ваш домен)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Секретный ключ для сессий и JWT (смените в продакшене!)
# Сгенерировать: openssl rand -base64 32
APP_SECRET="your-super-secret-key-change-in-production-min-32-chars"

# ===========================================
# RATE LIMITING
# ===========================================
# Максимальное количество запросов
RATE_LIMIT_MAX=10

# Окно времени в секундах
RATE_LIMIT_WINDOW=60

# ===========================================
# CACHE TTL (в секундах)
# ===========================================
# Кэш статистики игрока (15 минут)
CACHE_TTL_PLAYER=900

# Кэш кланов (30 минут)
CACHE_TTL_CLAN=1800

# Кэш миссий (10 минут)
CACHE_TTL_MISSIONS=600

# Кэш рейтингов (5 минут)
CACHE_TTL_RATINGS=300

# ===========================================
# ОПЦИОНАЛЬНО
# ===========================================
# Для отладки
# NODE_ENV="development"
# DEBUG="true"

