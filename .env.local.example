# ===========================================
# WARFACE TRACKER - LOCAL DEVELOPMENT
# ===========================================
# Скопируйте в .env.local и заполните значениями

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
# Для локальной разработки с Docker:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/warface_tracker"

# Для Vercel Postgres (раскомментируйте и вставьте ваш URL):
# DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# ===========================================
# REDIS
# ===========================================
# Для локальной разработки с Docker:
REDIS_URL="redis://localhost:6379"

# Для Vercel (Upstash/KV):
# REDIS_URL="redis://default:password@xxx.upstash.io:6379"

# ===========================================
# APP SETTINGS
# ===========================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Секретный ключ (сгенерируйте: openssl rand -base64 32)
APP_SECRET="your-super-secret-key-min-32-chars-long"

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60

# ===========================================
# CACHE TTL (в секундах)
# ===========================================
CACHE_TTL_PLAYER=900
CACHE_TTL_CLAN=1800
CACHE_TTL_MISSIONS=600
CACHE_TTL_RATINGS=300
